{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user information and summary stats",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "careerProgress": { "type": "number", "description": "Percentage of career roadmap completed" },
        "currentMilestone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "careerProgress"]
    },
    "Task": {
      "title": "Learning Task",
      "description": "A specific task for the user to complete",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tag": { "type": "string" },
        "tagColor": { "type": "string" },
        "status": { "type": "string", "enum": ["locked", "continue", "completed"] },
        "section": { "type": "string", "description": "e.g., Build Basics" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "section"]
    },
    "MoodEntry": {
      "title": "Mood Log",
      "description": "Daily mood check-in",
      "type": "object",
      "properties": {
        "score": { "type": "number", "description": "0-100 score for visualizing in chart" },
        "label": { "type": "string", "description": "Mood emoji or text" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["score", "createdAt"]
    },
    "AIQuery": {
      "title": "AI Query",
      "description": "Historical record of AI questions and answers",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "answer", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account information"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's individual tasks"
    },
    "/users/{userId}/mood_logs/{logId}": {
      "schema": "MoodEntry",
      "description": "User's daily mood history"
    },
    "/users/{userId}/ai_queries/{queryId}": {
      "schema": "AIQuery",
      "description": "User's AI interaction history"
    }
  }
}
